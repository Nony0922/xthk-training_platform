page { background: #f5f3ff; font-size: 28rpx; color: #374151; }
.container { padding: 24rpx; }
.card { background: #fff; border-radius: 16rpx; padding: 28rpx; margin-bottom: 24rpx; box-shadow: 0 4rpx 20rpx rgba(124,58,237,0.08); }
.card-title { font-size: 32rpx; font-weight: 600; color: #1f2937; margin-bottom: 12rpx; }
.card-desc { font-size: 26rpx; color: #6b7280; line-height: 1.6; }
.card-row { display: flex; justify-content: space-between; padding: 10rpx 0; font-size: 26rpx; }
.label { color: #9ca3af; }
.value { color: #374151; }
.price { color: #7c3aed; font-weight: 700; font-size: 34rpx; }
.empty { text-align: center; padding: 80rpx 0; color: #9ca3af; }
.btn-primary { background: linear-gradient(135deg, #7c3aed, #6d28d9); color: #fff; border-radius: 12rpx; font-size: 30rpx; }
.btn-outline { background: #fff; color: #7c3aed; border: 2rpx solid #7c3aed; border-radius: 12rpx; }
.tag { display: inline-block; padding: 4rpx 16rpx; border-radius: 8rpx; font-size: 22rpx; }
.tag-purple { background: #ede9fe; color: #7c3aed; }
.tag-green { background: #d1fae5; color: #065f46; }
.tag-orange { background: #ffedd5; color: #c2410c; }
.tag-gray { background: #f3f4f6; color: #6b7280; }
