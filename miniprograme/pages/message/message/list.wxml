<view class="container">
  <view class="input-card">
    <textarea class="textarea" placeholder="请输入留言内容..." value="{{content}}" bindinput="onInput" maxlength="500" />
    <button class="btn-primary" bindtap="submit">提交留言</button>
  </view>
  <view class="section-title">我的留言</view>
  <view wx:if="{{list.length===0}}" class="empty">暂无留言</view>
  <view class="card" wx:for="{{list}}" wx:key="id">
    <view class="card-desc">{{item.content}}</view>
    <view class="card-row"><text class="label">状态</text><text class="tag {{item.status===1?'tag-green':'tag-orange'}}">{{item.statusText}}</text></view>
    <view wx:if="{{item.reply}}" class="reply-box">
      <text class="reply-label">回复：</text>
      <text>{{item.reply}}</text>
    </view>
    <view class="card-row"><text class="label">时间</text><text class="value">{{item.createTime}}</text></view>
  </view>
</view>
