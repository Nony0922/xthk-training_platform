<view class="container">
  <view wx:if="{{list.length===0}}" class="empty">暂无可选课程</view>
  <view class="card" wx:for="{{list}}" wx:key="id" bindtap="goDetail" data-id="{{item.id}}">
    <view class="card-title">{{item.name}}</view>
    <view class="card-desc">{{item.description}}</view>
    <view class="card-row"><text class="label">任课教师</text><text class="value">{{item.teacherName || '-'}}</text></view>
    <view class="card-row"><text class="label">学时</text><text class="value">{{item.hours}} 课时</text></view>
    <view class="card-row"><text class="label">费用</text><text class="price">¥{{item.fee}}</text></view>
    <view class="card-footer"><text class="link">查看详情 / 购买 ›</text></view>
  </view>
</view>
