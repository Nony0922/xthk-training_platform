<view class="container" wx:if="{{course}}">
  <view class="hero">
    <text class="hero-title">{{course.name}}</text>
    <text class="hero-price">¥{{course.fee}}</text>
  </view>
  <view class="card">
    <view class="card-row"><text class="label">课程介绍</text></view>
    <view class="card-desc">{{course.description || '暂无介绍'}}</view>
  </view>
  <view class="card">
    <view class="card-row"><text class="label">任课教师</text><text class="value">{{course.teacherName || '-'}}</text></view>
    <view class="card-row"><text class="label">课程学时</text><text class="value">{{course.hours}} 课时</text></view>
    <view class="card-row"><text class="label">课程费用</text><text class="price">¥{{course.fee}}</text></view>
  </view>
  <button class="btn-primary" bindtap="addOrder">加入订单</button>
  <button class="btn-outline" style="margin-top:20rpx" bindtap="buyNow">立即购买并支付</button>
</view>
