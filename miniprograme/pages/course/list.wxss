@import '../../styles/common.wxss';

.filter-bar {
  display: flex;
  background: #fff;
  border-radius: 12rpx;
  padding: 8rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(124, 58, 237, 0.06);
}

.filter-item {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  font-size: 26rpx;
  color: #6b7280;
  border-radius: 8rpx;
}

.filter-item.active {
  background: #7c3aed;
  color: #fff;
  font-weight: 600;
}

.course-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(124, 58, 237, 0.08);
}

.course-card.disabled {
  opacity: 0.65;
}

.course-head {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 16rpx;
}

.course-name {
  flex: 1;
  font-size: 32rpx;
  font-weight: 600;
  color: #1f2937;
  padding-right: 16rpx;
}

.course-price {
  font-size: 36rpx;
  font-weight: 700;
  color: #7c3aed;
  flex-shrink: 0;
}

.tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.course-desc {
  font-size: 26rpx;
  color: #6b7280;
  line-height: 1.6;
  margin-bottom: 20rpx;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.info-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
  background: #f9fafb;
  border-radius: 12rpx;
  padding: 20rpx;
}

.info-cell {
  min-width: 0;
}

.info-label {
  display: block;
  font-size: 22rpx;
  color: #9ca3af;
  margin-bottom: 6rpx;
}

.info-value {
  display: block;
  font-size: 24rpx;
  color: #374151;
  word-break: break-all;
}

.card-footer {
  margin-top: 20rpx;
  text-align: right;
}

.link {
  color: #7c3aed;
  font-size: 26rpx;
  font-weight: 600;
}
