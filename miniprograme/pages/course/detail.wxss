@import '../../styles/common.wxss';

.page {
  padding: 24rpx 24rpx 180rpx;
}

.hero {
  background: linear-gradient(135deg, #7c3aed, #6d28d9);
  border-radius: 20rpx;
  padding: 32rpx;
  color: #fff;
  margin-bottom: 24rpx;
}

.hero .tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.hero .tag {
  background: rgba(255, 255, 255, 0.2);
  color: #fff;
}

.hero-title {
  display: block;
  font-size: 38rpx;
  font-weight: 700;
  line-height: 1.4;
}

.hero-price-row {
  display: flex;
  align-items: baseline;
  gap: 20rpx;
  margin-top: 16rpx;
}

.hero-price {
  font-size: 48rpx;
  font-weight: 700;
}

.hero-hours {
  font-size: 26rpx;
  opacity: 0.85;
}

.fit-tip {
  background: #ede9fe;
  color: #5b21b6;
  font-size: 24rpx;
  padding: 20rpx 24rpx;
  border-radius: 12rpx;
  margin-bottom: 24rpx;
  line-height: 1.6;
}

.fit-tip-warn {
  background: #fef3c7;
  color: #92400e;
}

.section-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(124, 58, 237, 0.08);
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1f2937;
  margin-bottom: 20rpx;
  padding-left: 16rpx;
  border-left: 6rpx solid #7c3aed;
}

.detail-table {
  border: 1rpx solid #f3f4f6;
  border-radius: 12rpx;
  overflow: hidden;
}

.detail-row {
  display: flex;
  padding: 20rpx 24rpx;
  border-bottom: 1rpx solid #f3f4f6;
  font-size: 26rpx;
}

.detail-row:last-child {
  border-bottom: none;
}

.detail-row:nth-child(even) {
  background: #fafafa;
}

.detail-label {
  width: 180rpx;
  color: #9ca3af;
  flex-shrink: 0;
}

.detail-value {
  flex: 1;
  color: #374151;
  word-break: break-all;
}

.highlight-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.highlight-item {
  display: flex;
  align-items: center;
  font-size: 26rpx;
  color: #374151;
}

.highlight-dot {
  color: #7c3aed;
  font-weight: 700;
  margin-right: 12rpx;
}

.desc-text {
  font-size: 28rpx;
  color: #4b5563;
  line-height: 1.8;
}

.notice-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.notice-item {
  font-size: 24rpx;
  color: #6b7280;
  line-height: 1.6;
}

.bottom-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: #fff;
  padding: 20rpx 24rpx calc(20rpx + env(safe-area-inset-bottom));
  display: flex;
  align-items: center;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.06);
  z-index: 100;
}

.bottom-price {
  flex: 1;
}

.bottom-label {
  display: block;
  font-size: 22rpx;
  color: #9ca3af;
}

.bottom-amount {
  font-size: 40rpx;
  font-weight: 700;
  color: #7c3aed;
}

.bottom-actions {
  display: flex;
  gap: 16rpx;
}

.btn-cart,
.btn-buy {
  font-size: 28rpx;
  padding: 0 32rpx;
  height: 72rpx;
  line-height: 72rpx;
  border-radius: 36rpx;
  margin: 0;
}

.btn-cart {
  background: #fff;
  color: #7c3aed;
  border: 2rpx solid #7c3aed;
}

.btn-buy {
  background: linear-gradient(135deg, #7c3aed, #6d28d9);
  color: #fff;
}

.btn-cart[disabled],
.btn-buy[disabled] {
  opacity: 0.5;
}
