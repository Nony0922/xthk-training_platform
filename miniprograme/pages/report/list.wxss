@import '../../styles/common.wxss';

.report-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.report-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 28rpx;
  box-shadow: 0 4rpx 16rpx rgba(124, 58, 237, 0.08);
}

.report-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1f2937;
  margin-bottom: 12rpx;
}

.report-question {
  font-size: 26rpx;
  color: #6b7280;
  line-height: 1.5;
  margin-bottom: 12rpx;
}

.report-meta {
  font-size: 24rpx;
  color: #9ca3af;
}

.report-arrow {
  margin-top: 16rpx;
  font-size: 26rpx;
  color: #7c3aed;
  text-align: right;
}
