@import '../../styles/common.wxss';

.title-card {
  background: linear-gradient(135deg, #7c3aed, #4c1d95);
  color: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.title {
  font-size: 36rpx;
  font-weight: 700;
  margin-bottom: 16rpx;
}

.summary {
  font-size: 28rpx;
  line-height: 1.7;
  opacity: 0.95;
}

.section {
  background: #fff;
  border-radius: 16rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #374151;
  margin-bottom: 20rpx;
}

.chart-card {
  margin-bottom: 20rpx;
}

.chart-title {
  font-size: 28rpx;
  color: #6b7280;
  margin-bottom: 16rpx;
}

.bar-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.bar-label {
  width: 120rpx;
  font-size: 24rpx;
  color: #374151;
  flex-shrink: 0;
}

.bar-track {
  flex: 1;
  height: 20rpx;
  background: #f3f4f6;
  border-radius: 999rpx;
  overflow: hidden;
}

.bar-fill {
  height: 100%;
  background: linear-gradient(90deg, #7c3aed, #a78bfa);
  border-radius: 999rpx;
}

.bar-value {
  width: 60rpx;
  text-align: right;
  font-size: 24rpx;
  color: #6b7280;
}

.chart-tip {
  font-size: 24rpx;
  color: #9ca3af;
}

.table-scroll {
  width: 100%;
}

.table-wrap {
  min-width: 100%;
}

.table-header, .table-row {
  display: flex;
}

.th, .td {
  min-width: 160rpx;
  padding: 16rpx 12rpx;
  font-size: 24rpx;
  border-bottom: 1rpx solid #f3f4f6;
}

.th {
  background: #f9fafb;
  color: #6b7280;
  font-weight: 600;
}

.td {
  color: #374151;
}

.analysis-item {
  margin-bottom: 24rpx;
}

.analysis-heading {
  font-size: 28rpx;
  font-weight: 600;
  color: #7c3aed;
  margin-bottom: 8rpx;
}

.analysis-content {
  font-size: 28rpx;
  line-height: 1.7;
  color: #374151;
  white-space: pre-wrap;
}
