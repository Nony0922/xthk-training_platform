<view class="container">
  <view wx:if="{{studentCount > 0}}" class="page-tip">{{tip}}</view>

  <view wx:if="{{studentCount === 0}}" class="empty">暂无关联学生</view>
  <view wx:elif="{{!hasData}}" class="empty">暂无考勤记录</view>

  <view class="student-section" wx:for="{{groups}}" wx:key="studentId">
    <view class="student-header">
      <view class="student-avatar">{{item.studentName[0]}}</view>
      <view class="student-info">
        <text class="student-name">{{item.studentName}}</text>
        <text class="student-class">{{item.className}}</text>
      </view>
      <text class="record-count">{{item.rows.length}} 条</text>
    </view>

    <view wx:if="{{item.rows.length === 0}}" class="section-empty">暂无考勤记录</view>
    <view wx:else class="table-wrap">
      <view class="table-header">
        <text class="th col-date">日期</text>
        <text class="th col-course">课程</text>
        <text class="th col-class">班级</text>
        <text class="th col-status">状态</text>
      </view>
      <view class="table-row" wx:for="{{item.rows}}" wx:for-item="row" wx:key="index">
        <text class="td col-date">{{row.attendDate}}</text>
        <text class="td col-course">{{row.courseName}}</text>
        <text class="td col-class">{{row.className}}</text>
        <view class="td col-status">
          <text class="tag {{row.statusClass}}">{{row.statusText}}</text>
        </view>
      </view>
    </view>
  </view>
</view>
