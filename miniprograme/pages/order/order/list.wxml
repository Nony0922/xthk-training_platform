<view class="container">
  <view wx:if="{{list.length===0}}" class="empty">暂无订单</view>
  <view class="card" wx:for="{{list}}" wx:key="id" bindtap="goDetail" data-id="{{item.id}}">
    <view class="card-row">
      <text class="card-title">{{item.courseName}}</text>
      <text class="tag {{item.status===1?'tag-green':item.status===0?'tag-orange':'tag-gray'}}">{{statusText[item.status]}}</text>
    </view>
    <view class="card-row"><text class="label">订单号</text><text class="value">{{item.orderNo}}</text></view>
    <view class="card-row"><text class="label">任课教师</text><text class="value">{{item.teacherName}}</text></view>
    <view class="card-row"><text class="label">学时</text><text class="value">{{item.hours}} 课时</text></view>
    <view class="card-row"><text class="label">费用</text><text class="price">¥{{item.fee}}</text></view>
    <button wx:if="{{item.status===0}}" class="btn-pay" catchtap="payOrder" data-id="{{item.id}}">立即支付</button>
  </view>
</view>
