@import '../../styles/common.wxss';
@import '../order/list.wxss';

.bottom-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 24rpx;
}

.bottom-actions .btn-primary,
.bottom-actions .btn-cancel {
  flex: 1;
  margin: 0;
  font-size: 28rpx;
  border-radius: 12rpx;
}

.bottom-actions .btn-primary {
  width: auto;
}

.bottom-actions .btn-cancel {
  background: #fff;
  color: #6b7280;
  border: 2rpx solid #d1d5db;
}
