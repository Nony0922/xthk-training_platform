<view class="container" wx:if="{{order}}">
  <view class="section-card">
    <view class="order-head">
      <text class="order-title">{{order.courseName}}</text>
      <text class="tag {{order.status===1?'tag-green':order.status===0?'tag-orange':'tag-gray'}}">{{statusText[order.status]}}</text>
    </view>
    <view class="info-row"><text class="info-label">订单号</text><text class="info-value">{{order.orderNo}}</text></view>
    <view class="info-row" wx:if="{{order.payTime}}"><text class="info-label">支付时间</text><text class="info-value">{{order.payTime}}</text></view>
  </view>

  <view class="section-card" wx:if="{{course}}">
    <view class="section-title">课程信息</view>
    <view class="info-table">
      <view class="info-row"><text class="info-label">适用年级</text><text class="info-value">{{course.targetGrade || '不限'}}</text></view>
      <view class="info-row"><text class="info-label">适合年龄</text><text class="info-value">{{course.suitableAge || '-'}}</text></view>
      <view class="info-row"><text class="info-label">授课方式</text><text class="info-value">{{course.teachModeFull}}</text></view>
      <view class="info-row"><text class="info-label">有效日期</text><text class="info-value">{{course.validPeriodText}}</text></view>
      <view class="info-row"><text class="info-label">上课时间</text><text class="info-value">{{course.classTimeDesc || '-'}}</text></view>
      <view class="info-row"><text class="info-label">上课地点</text><text class="info-value">{{course.location || '-'}}</text></view>
      <view class="info-row"><text class="info-label">任课教师</text><text class="info-value">{{order.teacherName}}</text></view>
      <view class="info-row"><text class="info-label">课程学时</text><text class="info-value">{{order.hours}} 课时</text></view>
      <view class="info-row"><text class="info-label">课程费用</text><text class="info-value price">¥{{order.fee}}</text></view>
    </view>
  </view>

  <view class="section-card" wx:if="{{course && course.description}}">
    <view class="section-title">课程介绍</view>
    <view class="desc-text">{{course.description}}</view>
  </view>

  <view wx:if="{{order.status===0}}" class="bottom-actions">
    <button class="btn-cancel" bindtap="cancelOrder">取消订单</button>
    <button class="btn-primary" bindtap="payOrder">立即支付 ¥{{order.fee}}</button>
  </view>
</view>
