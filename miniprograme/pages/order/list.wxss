@import '../../styles/common.wxss';

.order-card,
.section-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(124, 58, 237, 0.08);
}

.order-head {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 16rpx;
}

.order-title {
  flex: 1;
  font-size: 32rpx;
  font-weight: 600;
  color: #1f2937;
  padding-right: 16rpx;
}

.tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.info-table {
  border: 1rpx solid #f3f4f6;
  border-radius: 12rpx;
  overflow: hidden;
}

.info-row {
  display: flex;
  padding: 18rpx 20rpx;
  border-bottom: 1rpx solid #f3f4f6;
  font-size: 26rpx;
}

.info-row:last-child {
  border-bottom: none;
}

.info-row:nth-child(even) {
  background: #fafafa;
}

.info-label {
  width: 180rpx;
  color: #9ca3af;
  flex-shrink: 0;
}

.info-value {
  flex: 1;
  color: #374151;
  word-break: break-all;
}

.btn-pay {
  flex: 1;
  margin-top: 0;
  background: linear-gradient(135deg, #7c3aed, #6d28d9);
  color: #fff;
  border-radius: 12rpx;
  font-size: 28rpx;
}

.action-row {
  display: flex;
  gap: 16rpx;
  margin-top: 20rpx;
}

.btn-cancel {
  flex: 1;
  background: #fff;
  color: #6b7280;
  border: 2rpx solid #d1d5db;
  border-radius: 12rpx;
  font-size: 28rpx;
  margin: 0;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  margin-bottom: 16rpx;
  padding-left: 16rpx;
  border-left: 6rpx solid #7c3aed;
}

.desc-text {
  font-size: 28rpx;
  color: #4b5563;
  line-height: 1.8;
}

.btn-primary {
  width: 100%;
}
