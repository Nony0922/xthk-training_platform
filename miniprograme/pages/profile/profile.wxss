@import '../../styles/common.wxss';
.profile-header {
 background: linear-gradient(135deg, #7c3aed, #6d28d9); border-radius: 20rpx; padding: 48rpx; text-align: center; color: #fff; margin-bottom: 24rpx; }
.avatar { width: 100rpx; height: 100rpx; line-height: 100rpx; background: rgba(255,255,255,0.2); border-radius: 50%; font-size: 40rpx; margin: 0 auto 16rpx; }
.name { display: block; font-size: 36rpx; font-weight: 600; }
.role { display: block; font-size: 24rpx; opacity: 0.85; margin-top: 8rpx; }
.form-item { margin-bottom: 24rpx; }
.input { height: 72rpx; background: #f9fafb; border-radius: 8rpx; padding: 0 16rpx; border: 2rpx solid #e5e7eb; }
.menu-list { background: #fff; border-radius: 16rpx; overflow: hidden; margin: 24rpx 0; }
.menu-link { padding: 28rpx 32rpx; border-bottom: 1rpx solid #f3f4f6; font-size: 28rpx; color: #374151; }
.menu-link:last-child { border-bottom: none; }
.btn-logout { background: #fff; color: #ef4444; border: 2rpx solid #ef4444; border-radius: 12rpx; margin-top: 24rpx; }
.btn-primary { width: 100%; margin-top: 8rpx; }
