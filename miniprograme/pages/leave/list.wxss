@import '../../styles/common.wxss';

.action-bar {
  margin-bottom: 24rpx;
}

.btn-sm {
  font-size: 28rpx;
  padding: 16rpx 0;
}

.form-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(124, 58, 237, 0.08);
}

.form-item {
  margin-bottom: 24rpx;
}

.form-item .label {
  display: block;
  color: #6b7280;
  font-size: 26rpx;
  margin-bottom: 12rpx;
}

.picker-value {
  background: #f9fafb;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  color: #374151;
  font-size: 28rpx;
}

.picker-value.placeholder {
  color: #9ca3af;
}

.textarea {
  width: 100%;
  min-height: 160rpx;
  background: #f9fafb;
  border-radius: 12rpx;
  padding: 16rpx;
  box-sizing: border-box;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  margin-bottom: 16rpx;
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.reason {
  max-width: 420rpx;
  text-align: right;
  word-break: break-all;
}

.remark-box {
  background: #f5f3ff;
  padding: 16rpx;
  border-radius: 8rpx;
  margin: 12rpx 0;
  font-size: 26rpx;
  color: #4b5563;
}

.remark-label {
  color: #7c3aed;
  font-weight: 600;
}

.btn-withdraw {
  margin-top: 16rpx;
  font-size: 28rpx;
}
