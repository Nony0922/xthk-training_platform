<view class="container">
  <view wx:if="{{list.length===0}}" class="empty">暂无课程表信息</view>
  <view class="card" wx:for="{{list}}" wx:key="id">
    <view class="card-title">{{item.courseName}}</view>
    <view class="card-row"><text class="label">班级</text><text class="value">{{item.className}}</text></view>
    <view class="card-row"><text class="label">教师</text><text class="value">{{item.teacherName}}</text></view>
    <view class="card-row"><text class="label">星期</text><text class="value">{{item.weekdayText}}</text></view>
    <view class="card-row"><text class="label">时间</text><text class="value">{{item.startTime}} - {{item.endTime}}</text></view>
    <view class="card-row"><text class="label">教室</text><text class="value">{{item.room || '-'}}</text></view>
    <view class="card-row"><text class="label">学期</text><text class="value">{{item.semester || '-'}}</text></view>
  </view>
</view>
