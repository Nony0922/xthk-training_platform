@import '../../styles/common.wxss';

.welcome-card { background: linear-gradient(135deg, #7c3aed, #6d28d9); border-radius: 20rpx; padding: 40rpx; color: #fff; margin-bottom: 32rpx; }
.welcome { display: block; font-size: 36rpx; font-weight: 600; }
.welcome-sub { display: block; font-size: 24rpx; opacity: 0.85; margin-top: 8rpx; }
.section-title { font-size: 30rpx; font-weight: 600; color: #374151; margin: 24rpx 0 16rpx; }
.menu-grid { display: flex; flex-wrap: wrap; gap: 20rpx; margin-bottom: 24rpx; }
.menu-item { width: calc(33.33% - 14rpx); background: #fff; border-radius: 16rpx; padding: 28rpx 0; text-align: center; box-shadow: 0 4rpx 16rpx rgba(124,58,237,0.08); }
.menu-icon { font-size: 44rpx; margin-bottom: 8rpx; }
.menu-text { font-size: 24rpx; color: #4b5563; }
